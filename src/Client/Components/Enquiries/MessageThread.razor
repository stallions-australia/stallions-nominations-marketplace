@if (Messages is null || !Messages.Any())
{
    <EmptyState Message="No messages yet" Icon="💬" />
}
else
{
    <div class="message-thread">
        @foreach (var msg in Messages)
        {
            var isMine = CurrentUserId.HasValue && msg.SenderUserId == CurrentUserId.Value;
            var otherLabel = CurrentUserId == BuyerUserId ? "Stud Farm" : "Buyer";
            <div class="message @(isMine ? "message--buyer" : "message--farm")">
                <div class="message-sender">@(isMine ? "You" : otherLabel)</div>
                <div class="message-bubble">@msg.Body</div>
                <div class="message-time text-muted text-xs">@msg.SentAt.ToString("d MMM, h:mm tt")</div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<Stallions.Shared.DTOs.Enquiries.EnquiryMessageDto>? Messages { get; set; }
    [Parameter] public Guid? CurrentUserId { get; set; }
    /// <summary>
    /// The buyer's user ID from the enquiry. Used to determine which label to show
    /// for the other party: if the current user is the buyer, the other side is "Stud Farm";
    /// otherwise the current user is the stud farm admin and the other side is "Buyer".
    /// </summary>
    [Parameter] public Guid? BuyerUserId { get; set; }
}
