@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="modal-backdrop" @onclick="HandleBackdropClick"></div>
    <div class="modal-shell" @ref="_modalRef" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="modal-header">
            <h2 class="modal-title" id="modal-title">@Title</h2>
            <button class="modal-close" type="button" @onclick="OnClose" aria-label="Close">✕</button>
        </div>
        <div class="modal-body">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool CloseOnBackdrop { get; set; } = false;  // false: safer for checkout modals

    private ElementReference _modalRef;
    private bool _prevIsOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_prevIsOpen)
        {
            // Modal just opened — trap focus inside
            try { await JS.InvokeVoidAsync("modalFocus.trap", _modalRef); }
            catch { /* JS interop may not be available in tests */ }
        }
        _prevIsOpen = IsOpen;
    }

    private void HandleBackdropClick()
    {
        if (CloseOnBackdrop) OnClose.InvokeAsync();
    }
}
